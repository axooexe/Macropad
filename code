#include <Arduino.h>
#include <Keypad.h>
#include <Keyboard.h>


#define ROW_0 2  
#define ROW_1 3  
#define ROW_2 4  

#define COL_0 5  
#define COL_1 6  
#define COL_2 7  

const byte ROWS = 3;
const byte COLS = 3;


char keys[ROWS][COLS] = {
  {'9', '1', '2'},
  {'3', '4', '5'},
  {'6', '7', '8'}
};

byte rowPins[ROWS] = {ROW_0, ROW_1, ROW_2};
byte colPins[COLS] = {COL_0, COL_1, COL_2};

Keypad kpd = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

void setup() {
  Keyboard.begin();
}

void loop() {
  char key = kpd.getKey();
  if (key) {
    Keyboard.press(KEY_LEFT_GUI); 
    Keyboard.press(KEY_LEFT_ALT);
    Keyboard.press(key); 
    delay(15);
    Keyboard.releaseAll();
  }
}
